# Renomeie este arquivo para .env e preencha com os dados reais

# CNPJ da empresa emitente (somente números)
CNPJ_EMITENTE=12345678000100

# Inscrição Estadual do emitente (deixe vazio se for ISENTO)
IE_EMITENTE=

# Caminho completo para o certificado digital eCNPJ (.pfx ou .p12)
CERT_PATH=C:\Certificados\certificado.pfx

# Senha do certificado digital
CERT_PASSWORD=senha_do_certificado

# Arquivo de entrada com os dados DIFAL
ARQUIVO_ENTRADA=dados_difal.xlsx

# Diretório onde serão salvos os resultados
DIRETORIO_SAIDA=saida
